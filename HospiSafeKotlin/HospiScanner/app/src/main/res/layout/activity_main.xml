<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".view.MainActivity">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scanning Overlay -->
    <View
        android:id="@+id/scanOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/overlay_light"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <!-- Scan Frame -->
    <View
        android:id="@+id/scanFrame"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/scan_frame"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <!-- Title Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/titleText"
            style="@style/TitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scanner_title"
            android:textColor="@color/text_white" />

        <TextView
            android:id="@+id/instructionText"
            style="@style/SubtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/scanner_instruction"
            android:textColor="@color/text_white" />
    </LinearLayout>

    <!-- Bottom Container -->
    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminateTint="@color/accent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/statusText"
            style="@style/BodyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/scanning"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Permission Layout -->
    <LinearLayout
        android:id="@+id/permissionLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            style="@style/TitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/camera_permission_required"
            android:textColor="@color/text_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/grantPermissionButton"
            style="@style/PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/grant_permission" />
    </LinearLayout>

    <!-- Result Layout -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/resultLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/background"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Medical Report Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/TitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medical_report_title"
                    android:textColor="@color/text_white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/hospitalNameText"
                    style="@style/SubtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_white"
                    tools:text="Hospital General" />
            </LinearLayout>

            <!-- Success/Error Indicator -->
            <LinearLayout
                android:id="@+id/statusIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/success"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="12dp">

                <TextView
                    android:id="@+id/statusIndicatorText"
                    style="@style/BodyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_white"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/medicalReportContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Patient Information Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_dark_background"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            style="@style/SubtitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/patient_info"
                            android:textColor="@color/text_white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="12dp"
                            android:background="@color/text_white" />

                        <!-- Patient Name -->
                        <LinearLayout
                            android:id="@+id/patientNameLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/patient_name"
                                android:textColor="@color/text_dark_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/patientNameText"
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:textColor="@color/text_dark_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="Juan" />
                        </LinearLayout>

                        <!-- Last Name -->
                        <LinearLayout
                            android:id="@+id/lastNameLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/last_name"
                                android:textColor="@color/text_dark_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/lastNameText"
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:textColor="@color/text_dark_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="Pérez García" />
                        </LinearLayout>

                        <!-- DNI -->
                        <LinearLayout
                            android:id="@+id/dniLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/dni"
                                    android:textColor="@color/text_dark_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/dniText"
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:textColor="@color/text_dark_primary"
                                    android:textSize="16sp"
                                    tools:text="12345678" />
                            </LinearLayout>

                            <!-- Age -->
                            <LinearLayout
                                android:id="@+id/ageLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/age"
                                    android:textColor="@color/text_dark_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/ageText"
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:textColor="@color/text_dark_primary"
                                    android:textSize="16sp"
                                    tools:text="45 años" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Gender & Blood Type -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/genderLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/gender"
                                    android:textColor="@color/text_dark_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/genderText"
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:textColor="@color/text_dark_primary"
                                    android:textSize="16sp"
                                    tools:text="Masculino" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/bloodTypeLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/blood_type"
                                    android:textColor="@color/text_dark_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/bloodTypeText"
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:textColor="@color/text_dark_primary"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    tools:text="O+" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Room & Bed -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/roomLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/room"
                                    android:textColor="@color/text_dark_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/roomText"
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_dark_primary"
                                    android:textSize="16sp"
                                    tools:text="301" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/bedLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/bed"
                                    android:textColor="@color/text_dark_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/bedText"
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_dark_primary"
                                    android:textSize="16sp"
                                    tools:text="A" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Generated Date & Generated By -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">

                            <LinearLayout
                                android:id="@+id/generatedDateLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/generated_date"
                                    android:textColor="@color/text_dark_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/generatedDateText"
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_dark_primary"
                                    android:textSize="16sp"
                                    tools:text="2026-02-18" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/generatedByLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/generated_by"
                                    android:textColor="@color/text_dark_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/generatedByText"
                                    style="@style/BodyText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_dark_primary"
                                    android:textSize="16sp"
                                    tools:text="Sistema HospiScanner" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Medical Information Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/medicalInfoCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            style="@style/SubtitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/medical_info"
                            android:textColor="@color/primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="12dp"
                            android:background="@color/primary" />

                        <!-- Diagnosis -->
                        <LinearLayout
                            android:id="@+id/diagnosisLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/diagnosis"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/diagnosisText"
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                tools:text="Fractura de tibia" />
                        </LinearLayout>

                        <!-- Treatment -->
                        <LinearLayout
                            android:id="@+id/treatmentLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/treatment"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/treatmentText"
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                tools:text="Inmovilización y reposo" />
                        </LinearLayout>

                        <!-- Medications -->
                        <LinearLayout
                            android:id="@+id/medicationsLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/medications"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/medicationsText"
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                tools:text="Ibuprofeno 400mg" />
                        </LinearLayout>

                        <!-- Allergies -->
                        <LinearLayout
                            android:id="@+id/allergiesLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#FFF3E0"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:visibility="gone">

                            <TextView
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/allergies"
                                android:textColor="#E65100"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/allergiesText"
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#E65100"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                tools:text="Penicilina" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Doctor & Date Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/doctorDateCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Doctor -->
                        <LinearLayout
                            android:id="@+id/doctorLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/doctor"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/doctorText"
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                tools:text="Dr. García Martínez" />
                        </LinearLayout>

                        <!-- Date -->
                        <LinearLayout
                            android:id="@+id/dateLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <TextView
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/date"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/dateText"
                                style="@style/BodyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                tools:text="15/02/2026" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Additional Notes Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/notesCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            style="@style/SubtitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/additional_notes"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/notesText"
                            style="@style/BodyText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            tools:text="Observaciones adicionales" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Other Fields Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/otherFieldsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_darker_background"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            style="@style/SubtitleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/other_info"
                            android:textColor="@color/text_white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/otherFieldsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Error Card (when JSON is invalid) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/errorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/SubtitleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/error_processing"
                        android:textColor="@color/error"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/errorText"
                        style="@style/BodyText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/error"
                        tools:text="Error message" />

                    <TextView
                        style="@style/BodyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/raw_data"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/rawDataText"
                        style="@style/BodyText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true"
                        tools:text="Raw QR code data" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/copyButton"
                    style="@style/AccentButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="@string/copy_to_clipboard" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/scanAgainButton"
                    style="@style/PrimaryButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/scan_again" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

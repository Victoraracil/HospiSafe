<UserControl x:Class="HospiSafe.Views.InformesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HospiSafe.Views"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000"
             Background="{StaticResource Gray50}">
    <Grid>
        <!-- filas -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- cabecera -->
        <Border Grid.Row="0" Background="White" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📄" FontSize="24" Margin="0,0,12,0"/>
                <TextBlock Text="Gestión de Informes" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
            </StackPanel>
        </Border>
        <!-- contenido principal -->
        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.3*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="4.2*"/>
            </Grid.ColumnDefinitions>
            <!-- buscador -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#e2e8f0" BorderThickness="1" Padding="20" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="Buscar Paciente" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15"/>
                    <!-- busqueda -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Nombre, DNI o Seguridad Social" FontSize="12" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding TerminoBusqueda, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12,10" FontSize="14" VerticalContentAlignment="Center" Background="#f8fafc" BorderBrush="#cbd5e1" BorderThickness="1"/>
                    </StackPanel>
                    <!-- ayuda -->
                    <TextBlock Text="Comienza a escribir para filtrar pacientes" FontSize="11" Foreground="#94a3b8" Margin="0,0,0,20" TextWrapping="Wrap"/>
                    <Border Height="1" Background="#e2e8f0" Margin="0,0,0,20"/>
                    <!-- resultados -->
                    <TextBlock Text="Resultados" FontSize="12" FontWeight="SemiBold" Foreground="#0f172a" Margin="0,0,0,10"/>
                    <!-- lista -->
                    <ListBox ItemsSource="{Binding PacientesFiltrados}" SelectedItem="{Binding PacienteSeleccionado}" BorderThickness="0" Background="Transparent" MaxHeight="420" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#f8fafc" CornerRadius="8" Padding="12" Margin="0,0,0,8" BorderBrush="#cbd5e1" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" FontSize="13" Foreground="#0f172a" Margin="0,0,0,4">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="👤 {0} {1}">
                                                    <Binding Path="Nombre"/>
                                                    <Binding Path="Apellidos"/>
                                                </MultiBinding>
                                            </TextBlock.Text></TextBlock>
                                        <TextBlock Text="{Binding DNI, StringFormat='DNI: {0}'}" FontSize="12" Foreground="#475569"/>
                                        <TextBlock Text="{Binding NumSS, StringFormat='SS: {0}'}" FontSize="12" Foreground="#475569"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <!-- sin resultados -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,35,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding TerminoBusqueda}" Value=""/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding PacientesFiltrados.Count}" Value="0"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="🔍" FontSize="32" Opacity="0.3" HorizontalAlignment="Center"/>
                        <TextBlock Text="No se encontraron pacientes" FontSize="12" Foreground="#94a3b8" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- informes -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#e2e8f0" BorderThickness="1" Padding="20" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="Informes" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15"/>
                    <ListBox ItemsSource="{Binding Informes}"
                         SelectedItem="{Binding InformeSeleccionado}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <!-- tarjetas -->
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#f8fafc"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    BorderBrush="#cbd5e1"
                                    BorderThickness="1">
                                    <StackPanel>
                                        <!-- fecha -->
                                        <TextBlock Text="{Binding Fecha, StringFormat='📅 {0:dd/MM/yyyy HH:mm}'}"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Foreground="#0f172a"
                                           Margin="0,0,0,6"/>

                                        <!-- tipo analisis -->
                                        <TextBlock Text="{Binding Prueba.TipoAnalisis}"
                                           FontSize="12"
                                           Foreground="#475569"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
            <!-- visor -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#e2e8f0" BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- cabecera -->
                    <Border Grid.Row="0" Background="#f1f5f9" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{Binding InformeSeleccionado.Paciente.DNI}" FontWeight="Bold" FontSize="15" Foreground="#0f172a" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding InformeSeleccionado.Fecha, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}" FontSize="12" Foreground="#475569"/>
                        </StackPanel>
                    </Border>
                    <TabControl Grid.Row="1">
                        <!-- ver -->
                        <TabItem Header="Ver">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                   Text="Contenido del informe"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"
                                   Margin="0,0,0,8"/>

                                <Border Grid.Row="1"
                                    Background="#f8fafc"
                                    BorderBrush="#cbd5e1"
                                    BorderThickness="1"
                                    CornerRadius="6">

                                    <TextBox Text="{Binding InformeSeleccionado.Contenido}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="12"
                                         FontSize="13"
                                         Background="Transparent"
                                         BorderThickness="0"/>

                                </Border>

                                <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,15,0,0">

                                    <Button Content="Descargar PDF"
                                        Command="{Binding DescargarCommand}"
                                        Padding="14,8"
                                        Background="Transparent"
                                        BorderBrush="#cbd5e1"
                                        BorderThickness="1"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- editar -->
                        <TabItem Header="Editar">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                   Text="Contenido del informe"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"
                                   Margin="0,0,0,8"/>
                                <Border Grid.Row="1"
                                    Background="#f8fafc"
                                    BorderBrush="#cbd5e1"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <TextBox Text="{Binding ContenidoActual, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="12"
                                         FontSize="13"
                                         Background="Transparent"
                                         BorderThickness="0"/>
                                </Border>
                                <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,15,0,0">

                                    <Button Content="Guardar Cambios"
                                        Command="{Binding GuardarCommand}"
                                        Padding="14,8"
                                        Background="{StaticResource PrimaryColor}"
                                        Foreground="White"
                                        BorderThickness="0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
